[Unit]
Description=VR Arch Linux shell
After=network-online.target systemd-user-sessions.service
Wants=network-online.target

[Service]
Type=simple
Environment=VR_OS_HOST=127.0.0.1
Environment=VR_OS_PORT=8080
ExecStart=/usr/bin/xinit /usr/local/bin/vr-session -- :0 vt1 -nolisten tcp -keeptty
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target